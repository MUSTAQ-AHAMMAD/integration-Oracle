# Oracle CRM – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Oracle Fusion Cloud ──────────────────────────────────────────────────────
# The full base URL, e.g. https://ehxk-test.fa.em2.oraclecloud.com
FUSION_BASE_URL=https://{your-instance}.fa.{region}.oraclecloud.com

# Oracle Fusion REST API credentials (HTTP Basic Auth)
FUSION_USERNAME={your-oracle-fusion-username}
FUSION_PASSWORD={retrieve-from-secrets-manager}

# ── Odoo ERP Connection ───────────────────────────────────────────────────────
# Odoo server base URL (no trailing slash)
ODOO_URL=https://{your-odoo-instance}.odoo.com

# Odoo database name (visible on the login page or in Settings > Database)
ODOO_DB={your-odoo-db-name}

# Odoo login credentials (user must have Sales / Read access)
ODOO_USERNAME={your-odoo-username}
ODOO_PASSWORD={your-odoo-password-or-api-key}

# Max concurrent Oracle API calls per Odoo push job (default: 3)
# Increase to speed up bulk pushes; lower to keep the CRM more responsive.
ODOO_PUSH_CONCURRENCY=3

# Number of sale orders fetched per page from Odoo (default: 500).
# Reduce if Odoo returns timeouts on large date ranges.
ODOO_FETCH_PAGE_SIZE=500

# Number of SQLite records processed per batch during a push job (default: 500).
# Keeps memory usage flat regardless of total order count.
PUSH_BATCH_SIZE=500

# ── Integration Database (Oracle DB) ─────────────────────────────────────────
# Only needed for the optional "read from DB" features.
# DB_USER=integration_user
# DB_PASSWORD={db-password}
# DB_CONNECTION_STRING=144.21.xx.xx:1521/INTEG

# ── CRM Server ───────────────────────────────────────────────────────────────
PORT=3000

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info

# ── Region defaults ──────────────────────────────────────────────────────────
# Comma-separated list of regions your outlets use
REGIONS=AE,KW,OM,SA,BH,QA
