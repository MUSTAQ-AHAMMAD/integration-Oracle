# Oracle CRM – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Oracle Fusion Cloud ──────────────────────────────────────────────────────
# The full base URL, e.g. https://ehxk-test.fa.em2.oraclecloud.com
FUSION_BASE_URL=https://{your-instance}.fa.{region}.oraclecloud.com

# Oracle Fusion REST API credentials (HTTP Basic Auth)
FUSION_USERNAME={your-oracle-fusion-username}
FUSION_PASSWORD={retrieve-from-secrets-manager}

# ── Odoo ERP Connection ───────────────────────────────────────────────────────
# Odoo server base URL (no trailing slash)
ODOO_URL=https://{your-odoo-instance}.odoo.com

# Odoo login credentials (user must have Sales / Read access)
ODOO_USERNAME={your-odoo-username}
ODOO_PASSWORD={your-odoo-password-or-api-key}

# Max concurrent Oracle API calls per Odoo push job (default: 10)
# Increase to speed up bulk pushes; lower to keep the CRM more responsive.
# For 8 000 orders in 2-3 hours, values of 10-20 are recommended.
ODOO_PUSH_CONCURRENCY=10

# Number of sale orders fetched per page from Odoo (default: 500).
# Reduce if Odoo returns timeouts on large date ranges.
ODOO_FETCH_PAGE_SIZE=500

# Max concurrent Odoo line-chunk fetch requests (default: 5).
# Fetching order lines is parallelised with this limit to speed up the fetch phase.
ODOO_LINE_FETCH_CONCURRENCY=5

# Number of SQLite records processed per batch during a push job (default: 500).
# Keeps memory usage flat regardless of total order count.
PUSH_BATCH_SIZE=500

# ── Integration Database (Oracle DB) ─────────────────────────────────────────
# Optional Oracle database connection for reading fusion metadata directly.
# When enabled, the middleware can query metadata from Oracle instead of CSV files.
#
# Example configuration for Oracle database with SYSDBA role:
# ORACLE_DB_HOST=193.122.68.27
# ORACLE_DB_PORT=1521
# ORACLE_DB_SERVICE_NAME=TestDB_jed1sw.dbsubnet.testvcn.oraclevcn.com
# ORACLE_DB_USERNAME=SYS
# ORACLE_DB_PASSWORD=Tamer_innovate123
# ORACLE_DB_ROLE=SYSDBA
# ORACLE_DB_ENABLED=true
#
# For standard connections, leave ORACLE_DB_ROLE empty or unset.
# Supported roles: SYSDBA, SYSOPER (for system administrator privileges)
#
# Note: These settings can also be configured via the UI at /config
# DB_USER=integration_user
# DB_PASSWORD={db-password}
# DB_CONNECTION_STRING=144.21.xx.xx:1521/INTEG

# ── CRM Server ───────────────────────────────────────────────────────────────
PORT=3000

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info

# ── Region defaults ──────────────────────────────────────────────────────────
# Comma-separated list of regions your outlets use
REGIONS=AE,KW,OM,SA,BH,QA
