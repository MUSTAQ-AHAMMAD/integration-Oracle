<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE html>
<f:view xmlns:f="http://java.sun.com/jsf/core" xmlns:af="http://xmlns.oracle.com/adf/faces/rich" 
afterPhase="#{pageFlowScope.IntegrationSchedulerBean.afterPhase}">
    <af:document title="HomePage.jsf" id="d1" >
        <af:messages id="m1"/>
        <af:form id="f1">
            <af:pageTemplate viewId="/oracle/templates/responsiveTemplate.jspx" id="pt1">
                <f:facet name="header">
                    <af:outputText value="&nbsp;&nbsp;&nbsp;|&nbsp;&nbsp;&nbsp;Integration Middleware"
                                   id="ot9"/>
                </f:facet>
                <f:facet name="status"/>
                <f:facet name="appNav">
                    <af:button text="Settings" id="b4" inlineStyle="font-size:large;" action="adfMenu_GeneralSettings"
                               icon="/images/baseline_settings_black_24dp.png" visible="#{securityContext.userInRole['admin_role']}"/>
                    <af:button text="On-Hand Qty" id="b5" inlineStyle="font-size:large;" action="adfMenu_OnHandDetails"
                               icon="/images/baseline_equalizer_black_24dp.png"/>
                    <af:button text="Store Sales" id="b3"  inlineStyle="font-size:large;" action="adfMenu_VendHQSales"
                               icon="/images/baseline_shopping_basket_black_24dp.png"/>
                </f:facet>
                <f:facet name="globalLinks">
                    <af:outputText value="Hi #{securityContext.userName}, Welcome!&nbsp;&nbsp;" id="ot101"/>
                    <af:button text="Logout" id="b18"
                               actionListener="#{pageFlowScope.IntegrationSchedulerBean.logoutAction}"/>
                    <af:panelGroupLayout id="pgl8" inlineStyle="margin-right:250px;"/>
                    
                    <af:toolbar id="t10">
                        <af:selectOneChoice value="#{bindings.SelectedRegion.inputValue}"
                                            label="Select Region: "
                                            required="#{bindings.SelectedRegion.hints.mandatory}"
                                            shortDesc="#{bindings.SelectedRegion.hints.tooltip}" id="soc1" autoSubmit="true">
                            <f:selectItems value="#{bindings.SelectedRegion.items}" id="si1"/>
                            <f:validator binding="#{bindings.SelectedRegion.validator}"/> 
                        </af:selectOneChoice>
                        <af:button text="Change" id="b8"
                                   actionListener="#{pageFlowScope.IntegrationSchedulerBean.changeSelectedRegion}"/>
                    </af:toolbar>
                </f:facet>
                <f:facet name="footer">
                    <af:outputText value="Copyright (C) Tamer Innovate. All Rights Reserved." id="ot14"
                                   inlineStyle="width:inherit; flex-align:center;"/>
                </f:facet>
                <f:facet name="center">
                    <af:panelStretchLayout id="psl1"
                                           visible="#{securityContext.userInRole['operator_role']}">
                        <f:facet name="start"/>
                        <f:facet name="end"/>
                        <f:facet name="top">
                            <af:panelGridLayout id="pgl1">
                                <af:gridRow marginTop="5px" height="auto" marginBottom="5px" id="gr1">
                                    <af:gridCell marginStart="5px" width="50%" id="gc1" styleClass="AFStretchWidth">
                                        <af:decorativeBox id="db1" styleClass="AFStretchWidth">
                                            <f:facet name="top"/>
                                            <f:facet name="center">
                                                <af:outputText value="VendHQ Integration Control" id="ot100"
                                                               inlineStyle="font-size:large;"/>
                                            </f:facet>
                                        </af:decorativeBox>
                                    </af:gridCell>
                                </af:gridRow>
                            </af:panelGridLayout>
                        </f:facet>
                        <f:facet name="bottom"/>
                        <f:facet name="center">
                            <af:panelDashboard id="pd1" columns="4" rowHeight="280px">
                                <af:panelBox text="Item Status" id="pb3" showDisclosure="false"
                                                inlineStyle="background-color:#DCEDC8;"
                                             icon="/images/baseline_dashboard_black_24dp.png">
                                    <f:facet name="toolbar">
                                        <af:toolbar id="t2">
                                            <af:button text="Refresh" id="b2"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.refreshItemStatusLayout}"
                                                       icon="/images/baseline_refresh_black_18dp.png"/>
                                            <af:button text="Start" id="b1" visible="false"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.toggleItemsSchedulerStatus}"
                                                       binding="#{pageFlowScope.IntegrationSchedulerBean.changeItemStatusButton}"
                                                       partialTriggers="b1 ot16 pi1"/>
                                        </af:toolbar>
                                    </f:facet>
                                    <af:panelGroupLayout id="pgl3" layout="vertical" visible="false"
                                                                        styleClass="AFStretchWidth"
                                                                        binding="#{pageFlowScope.IntegrationSchedulerBean.itemStatusLayout}">
                                        <af:progressIndicator id="pi1" clientComponent="true"
                                                              binding="#{pageFlowScope.IntegrationSchedulerBean.itemStatusIndicator}"
                                                              inlineStyle="margin:0px; margin-bottom:10px; margin-left:10px; margin-right:10px; margin-top:10px;"/>
                                        <af:panelGridLayout id="pgl6">
                                            <af:gridRow marginTop="15px" height="auto" id="gr6">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc8">
                                                    <af:outputText value="Scheduler is Running..." id="ot16"
                                                                   clientComponent="true"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.itemStatusText}"
                                                                   inlineStyle="padding:10px; font-style:italic; font-weight:bold;"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow marginTop="5px" height="auto" id="gr7">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc9">
                                                    <af:outputText value="" id="ot102"
                                                                   inlineStyle="color:#840000; padding:10px;"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.itemStatusPrevDate}"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow marginTop="5px" height="auto" marginBottom="5px" id="gr8">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc10">
                                                    <af:outputText value="" id="ot103"
                                                                   inlineStyle="color:Blue; padding:10px;"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.itemStatusNextDate}"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                        </af:panelGridLayout>
                                    </af:panelGroupLayout>
                                </af:panelBox>
                                <af:panelBox text="Sales Status" id="pb4" showDisclosure="false"
                                                inlineStyle="background-color:#DCEDC8;"
                                             icon="/images/baseline_shopping_cart_black_18dp.png">
                                    <f:facet name="toolbar">
                                        <af:toolbar id="t11">
                                            <af:button text="Refresh" id="b7"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.refreshSalesStatusLayout}"
                                                       icon="/images/baseline_refresh_black_18dp.png"/>
                                            <af:button text="Start" id="b51" visible="false"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.toggleSalesSchedulerStatus}"
                                                       binding="#{pageFlowScope.IntegrationSchedulerBean.changeSalesStatusButton}"
                                                       partialTriggers="b5 ot183 pi2"/>
                                        </af:toolbar>
                                    </f:facet>
                                    <af:panelGroupLayout id="pgl45" layout="vertical"  visible="false"
                                                                        styleClass="AFStretchWidth"
                                                                        binding="#{pageFlowScope.IntegrationSchedulerBean.salesStatusLayout}">
                                        <af:progressIndicator id="pi2" clientComponent="true" inlineStyle="margin:0px; margin-bottom:10px; margin-left:10px; margin-right:10px; margin-top:10px;"
                                                              binding="#{pageFlowScope.IntegrationSchedulerBean.salesStatusIndicator}"/>
                                        <af:panelGridLayout id="pgl5">
                                            <af:gridRow marginTop="15px" height="auto" id="gr3">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc5">
                                                    <af:outputText value="Scheduler is Running..." id="ot183"
                                                                   clientComponent="true"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.salesStatusText}"
                                                                   inlineStyle="padding:10px; font-style:italic; font-weight:bold;"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow marginTop="5px" height="auto" id="gr4">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc6">
                                                    <af:outputText value="" id="ot104"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.salesStatusPrevDate}"
                                                                   inlineStyle="color:#840000; padding:10px;"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow marginTop="5px" height="auto" marginBottom="5px" id="gr5">
                                                <af:gridCell marginStart="5px" width="100%" marginEnd="5px" id="gc7">
                                                    <af:outputText value="" id="ot105"
                                                                   binding="#{pageFlowScope.IntegrationSchedulerBean.salesStatusNextDate}"
                                                                   inlineStyle="color:Blue; padding:10px;"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                        </af:panelGridLayout>
                                    </af:panelGroupLayout>
                                </af:panelBox>
                                <af:panelBox text="Manual Sync" id="pb5" showDisclosure="false"
                                             icon="/images/baseline_assignment_returned_black_18dp.png">
                                    <af:panelGroupLayout id="pgl7" layout="vertical"
                                                         binding="#{pageFlowScope.IntegrationSchedulerBean.salesManualLayout}">
                                        <af:panelGridLayout id="pgl10">
                                            <af:gridRow marginTop="15px" height="auto" id="gr9">
                                                <af:gridCell marginStart="5px" width="100%" id="gc11">
                                                    <af:panelGroupLayout id="pgl9"
                                                                         inlineStyle="margin:5px; padding:5px;">
                                                        <af:outputText value="Outlets to Integrate: " id="ot113"/>
                                                        <af:outputText value="" id="ot114"
                                                                       inlineStyle="color:Orange; padding:10px;"
                                                                       binding="#{pageFlowScope.IntegrationSchedulerBean.manualOutletList}"/>
                                                    </af:panelGroupLayout>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow marginTop="15px" height="auto" marginBottom="5px" id="gr10">
                                                <af:gridCell marginStart="5px" width="100%" id="gc12" inlineStyle="margin:5px;">
                                                    <af:inputNumberSpinbox label="Days: " id="ins1" visible="#{securityContext.userInRole['admin_role']}"
                                                                           binding="#{pageFlowScope.IntegrationSchedulerBean.daysToIntegrate}"
                                                                           inlineStyle="margin:5px;"/>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow id="gr11">
                                                <af:gridCell id="gc2">
                                                    <af:panelBorderLayout id="pbl1">
                                                        <f:facet name="top"/>
                                                        <f:facet name="bottom"/>
                                                        <f:facet name="start"/>
                                                        <f:facet name="end"/>
                                                        <af:toolbar id="t20">
                                                            <af:button text="Sync Automated Outlets" id="b19"
                                                                       icon="/images/baseline_sync_black_18dp.png"
                                                                       visible="#{securityContext.userInRole['operator_role']}"
                                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.runSalesAutomatedOnce}"/>
                                                        </af:toolbar>
                                                    </af:panelBorderLayout>
                                                </af:gridCell>
                                            </af:gridRow>
                                            <af:gridRow id="gr12">
                                                <af:gridCell id="gc3">
                                                    <af:panelBorderLayout id="pbl2">
                                                        <f:facet name="top"/>
                                                        <f:facet name="bottom"/>
                                                        <f:facet name="start"/>
                                                        <f:facet name="end"/>
                                                        <af:toolbar id="t29">
                                                            <af:button text="Sync Items" id="b29"
                                                                       icon="/images/baseline_dashboard_black_24dp.png"
                                                                       visible="#{securityContext.userInRole['operator_role']}"
                                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.runItemsSyncAutomatedOnce}"/>
                                                        </af:toolbar>
                                                    </af:panelBorderLayout>
                                                </af:gridCell>
                                            </af:gridRow>
                                        </af:panelGridLayout>
                                    </af:panelGroupLayout>
                                    <f:facet name="toolbar">
                                        <af:toolbar id="t12">
                                            <af:button text="Refresh" id="b9"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.refreshSalesManualLayout}"
                                                       icon="/images/baseline_refresh_black_18dp.png"
                                                       visible="#{securityContext.userInRole['admin_role']}"/>
                                            <af:button text="Run Once" id="b6" partialTriggers="salesLog" visible="false"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.runSalesJobOnce}"
                                                       icon="/images/baseline_warning_black_18dp.png"
                                                       binding="#{pageFlowScope.IntegrationSchedulerBean.runSalesJobOnceButton}"/>
                                        </af:toolbar>
                                    </f:facet>
                                </af:panelBox>
                                <af:panelBox text="Physical Inventory" id="pb6" showDisclosure="false"
                                             icon="/images/baseline_account_box_black_18dp.png">
                                    <af:panelGroupLayout id="pgl11" inlineStyle="margin:10px; padding:5px;">
                                        <af:toolbar id="t21">
                                            <af:selectOneChoice value="#{bindings.VendhqOutletsView1.inputValue}"
                                                                label="#{bindings.VendhqOutletsView1.label}"
                                                                required="#{bindings.VendhqOutletsView1.hints.mandatory}"
                                                                shortDesc="#{bindings.VendhqOutletsView1.hints.tooltip}"
                                                                id="soc2"
                                                                binding="#{pageFlowScope.IntegrationSchedulerBean.inventoryOutletName}">
                                                <f:selectItems value="#{bindings.VendhqOutletsView1.items}" id="si2"/>
                                                <f:validator binding="#{bindings.VendhqOutletsView1.validator}"/>
                                            </af:selectOneChoice>
                                        </af:toolbar>
                                    </af:panelGroupLayout>
                    
                                    <f:facet name="toolbar">
                                        <af:toolbar id="t3">
                                            <af:button text="Sync Inventory" id="b10"
                                                       icon="/images/baseline_sync_black_18dp.png"
                                                       actionListener="#{pageFlowScope.IntegrationSchedulerBean.runInventorySync}"/>
                                        </af:toolbar>
                                    
                                    </f:facet>
                                </af:panelBox>
                            </af:panelDashboard>
                        </f:facet>
                    </af:panelStretchLayout>
                    <af:panelGroupLayout id="pgl2" styleClass="AFStretchWidth" layout="vertical">
                        <af:panelAccordion discloseMany="false" id="pa1">
                            <af:showDetailItem id="salesLog" text="Sales Integration Log"
                                               icon="/images/baseline_shopping_cart_black_18dp.png">
                                <af:panelTabbed position="above" id="pt2">
                                    <af:showDetailItem id="tab1" text="Invoice Header">
                                        <af:panelCollection id="pc1" inlineStyle="width:inherit;">
                                            <f:facet name="menus"/>
                                            <f:facet name="toolbar">
                                                <af:toolbar id="t13">
                                                    <af:button text="Export Filtered Rows to Excel" id="b11">
                                                        <af:exportCollectionActionListener type="excelHTML"
                                                                                           exportedId="t4"
                                                                                           filename="Sales Integration Invoice Header Data.xls"/>
                                                    </af:button>
                                                </af:toolbar>
                                            </f:facet>
                                            <f:facet name="statusbar"/>
                                            <af:table value="#{bindings.FusionInvoiceHeaderView1.collectionModel}"
                                                      var="row" rows="#{bindings.FusionInvoiceHeaderView1.rangeSize}"
                                                      emptyText="#{bindings.FusionInvoiceHeaderView1.viewable ? 'No data to display.' : 'Access Denied.'}"
                                                      rowBandingInterval="0"
                                                      selectedRowKeys="#{bindings.FusionInvoiceHeaderView1.collectionModel.selectedRow}"
                                                      selectionListener="#{bindings.FusionInvoiceHeaderView1.collectionModel.makeCurrent}"
                                                      rowSelection="single"
                                                      fetchSize="#{bindings.FusionInvoiceHeaderView1.rangeSize}"
                                                      filterModel="#{bindings.FusionInvoiceHeaderView1Query.queryDescriptor}"
                                                      filterVisible="true"
                                                      queryListener="#{bindings.FusionInvoiceHeaderView1Query.processQuery}"
                                                      varStatus="vs" id="t4" partialTriggers="::b8 :::b8">
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.RequestId.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.RequestId.label}"
                                                           id="c9">
                                                    <af:outputText value="#{row.RequestId}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.RequestId.tooltip}"
                                                                   id="ot17">
                                                        <af:convertNumber groupingUsed="false"
                                                                          pattern="#{bindings.FusionInvoiceHeaderView1.hints.RequestId.format}"/>
                                                    </af:outputText>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.Status.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.Status.label}"
                                                           id="c16">
                                                    <af:outputText value="#{row.Status}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.Status.tooltip}"
                                                                   id="ot18"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.Message.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.Message.label}"
                                                           id="c17">
                                                    <af:outputText value="#{row.Message}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.Message.tooltip}"
                                                                   id="ot19"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.RequestDate.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.RequestDate.label}"
                                                           id="c18">
                                                    <f:facet name="filter">
                                                        <af:inputDate value="#{bindings.FusionInvoiceHeaderView1Query.queryDescriptor.filterConjunctionCriterion.criterionMap.RequestDate.value}"
                                                                      id="id3">
                                                            <af:convertDateTime pattern="#{bindings.FusionInvoiceHeaderView1.hints.RequestDate.format}"/>
                                                        </af:inputDate>
                                                    </f:facet>
                                                    <af:outputText value="#{row.RequestDate}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.RequestDate.tooltip}"
                                                                   id="ot20">
                                                        <af:convertDateTime pattern="#{bindings.FusionInvoiceHeaderView1.hints.RequestDate.format}"/>
                                                    </af:outputText>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.TxnDate.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.TxnDate.label}"
                                                           id="c19">
                                                    <f:facet name="filter">
                                                        <af:inputDate value="#{bindings.FusionInvoiceHeaderView1Query.queryDescriptor.filterConjunctionCriterion.criterionMap.TxnDate.value}"
                                                                      id="id4">
                                                            <af:convertDateTime pattern="#{bindings.FusionInvoiceHeaderView1.hints.TxnDate.format}"/>
                                                        </af:inputDate>
                                                    </f:facet>
                                                    <af:outputText value="#{row.TxnDate}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.TxnDate.tooltip}"
                                                                   id="ot21">
                                                        <af:convertDateTime pattern="#{bindings.FusionInvoiceHeaderView1.hints.TxnDate.format}"/>
                                                    </af:outputText>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.BusinessUnit.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.BusinessUnit.label}"
                                                           id="c20">
                                                    <af:outputText value="#{row.BusinessUnit}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.BusinessUnit.tooltip}"
                                                                   id="ot22"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.BillToCustName.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.BillToCustName.label}"
                                                           id="c21">
                                                    <af:outputText value="#{row.BillToCustName}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.BillToCustName.tooltip}"
                                                                   id="ot23"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.TxnNumber.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.TxnNumber.label}"
                                                           id="c22">
                                                    <!-- <af:outputText value="#{row.TxnNumber}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.TxnNumber.tooltip}"
                                                                   id="ot24">
                                                        <af:convertNumber groupingUsed="false"
                                                                          pattern="#{bindings.FusionInvoiceHeaderView1.hints.TxnNumber.format}"/>
                                                    </af:outputText> -->
                                                    <af:link text="#{row.TxnNumber}" id="l1"
                                                             useWindow="true" windowModalityType="applicationModal"
                                                             windowEmbedStyle="window" windowHeight="800"
                                                             windowWidth="1600" targetFrame="_blank"
                                                            destination="/faces/FusionInvoiceDetails.jsf?txnNumber=#{row.TxnNumber}---#{bindings.SelectedRegion.inputValue}"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.CurrencyCode.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.CurrencyCode.label}"
                                                           id="c23">
                                                    <af:outputText value="#{row.CurrencyCode}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.CurrencyCode.tooltip}"
                                                                   id="ot25"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.BillToLocation.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.BillToLocation.label}"
                                                           id="c24">
                                                    <af:outputText value="#{row.BillToLocation}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.BillToLocation.tooltip}"
                                                                   id="ot26"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.BillToAccNumber.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.BillToAccNumber.label}"
                                                           id="c25">
                                                    <af:outputText value="#{row.BillToAccNumber}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.BillToAccNumber.tooltip}"
                                                                   id="ot27">
                                                        <af:convertNumber groupingUsed="false"
                                                                          pattern="#{bindings.FusionInvoiceHeaderView1.hints.BillToAccNumber.format}"/>
                                                    </af:outputText>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.PaymentTermsName.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.PaymentTermsName.label}"
                                                           id="c26">
                                                    <af:outputText value="#{row.PaymentTermsName}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.PaymentTermsName.tooltip}"
                                                                   id="ot28"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.TxnSource.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.TxnSource.label}"
                                                           id="c27">
                                                    <af:outputText value="#{row.TxnSource}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.TxnSource.tooltip}"
                                                                   id="ot29"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.TxnType.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.TxnType.label}"
                                                           id="c28">
                                                    <af:outputText value="#{row.TxnType}"
                                                                   shortDesc="#{bindings.FusionInvoiceHeaderView1.hints.TxnType.tooltip}"
                                                                   id="ot30"/>
                                                </af:column>
                                                <af:column sortProperty="#{bindings.FusionInvoiceHeaderView1.hints.GlDate.name}"
                                                           filterable="true" sortable="true"
                                                           headerText="#{bindings.FusionInvoiceHeaderView1.hints.GlDate.label}"
                                                           id="c29">
                                                    <f:facet name="filter">
                                                        <af:inputDate value="#{bindings.FusionInvoiceHeaderView1Query.queryDescriptor.filterConjunctionCriterion.criterionMap.GlDate.value}"
                                                                      id="id5">
                                                            <af:convertDateTime pattern="#{bindings.FusionInvoiceHeaderView1.hints.GlDate.format}"/>
                                                        </af:inputDate>
                                                    </f:facet>
