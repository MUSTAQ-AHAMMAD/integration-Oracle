                                                   id="c18">
                                            <f:facet name="filter">
                                                <af:inputDate value="#{bindings.VendhqCredentialsView2Query.queryDescriptor.filterConjunctionCriterion.criterionMap.BusinessStartDate.value}"
                                                              id="id3">
                                                    <af:convertDateTime pattern="#{bindings.VendhqCredentialsView2.hints.BusinessStartDate.format}"/>
                                                </af:inputDate>
                                            </f:facet>
                                            <af:outputText value="#{row.BusinessStartDate}"
