                                                        <af:convertDateTime pattern="#{bindings.VendhqRegistersView1.hints.DeletedAt.format}"/>
                                                    </af:inputDate>
                                                </f:facet>
                                                <af:outputText value="#{row.DeletedAt}"
                                                               shortDesc="#{bindings.VendhqRegistersView1.hints.DeletedAt.tooltip}"
                                                               id="ot10">
                                                    <af:convertDateTime pattern="#{bindings.VendhqRegistersView1.hints.DeletedAt.format}"/>
                                                </af:outputText>
                                            </af:column>
                                        </af:table>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                </af:decorativeBox>
                            </af:showDetailItem>
                            <af:showDetailItem id="taxes" text="Outlets Automation">
                                <af:decorativeBox id="db3">
                                    <f:facet name="top">
                                        <af:toolbar id="t6">
                                            <af:selectOneChoice value="#{bindings.Selected_Region2.inputValue}"
                                                                label="Select Region"
                                                                required="#{bindings.Selected_Region2.hints.mandatory}"
                                                                shortDesc="#{bindings.Selected_Region2.hints.tooltip}"
                                                                id="soc3">
                                                <f:selectItems value="#{bindings.Selected_Region2.items}" id="si8"/>
                                                <f:validator binding="#{bindings.Selected_Region2.validator}"/>
                                            </af:selectOneChoice>
                                            <af:button actionListener="#{bindings.ExecuteWithParams2.execute}"
                                                       text="Change"
                                                       disabled="#{!bindings.ExecuteWithParams2.enabled}" id="b16"/>
                                            <af:button text="Submit" id="b13" inlineStyle="margin-left:50px;"/>
                                            <af:button text="Sync Outlets" id="b17"
                                                       actionListener="#{pageFlowScope.VendHQSettingsBean.syncOutletsConfig}"/>
                                        </af:toolbar>
                                    </f:facet>
                                    <f:facet name="center">
                                        <af:table value="#{bindings.OutletsIntegrationConfigView1.collectionModel}"
                                                  var="row" rows="#{bindings.OutletsIntegrationConfigView1.rangeSize}"
                                                  emptyText="#{bindings.OutletsIntegrationConfigView1.viewable ? 'No data to display.' : 'Access Denied.'}"
                                                  rowBandingInterval="0"
                                                  selectedRowKeys="#{bindings.OutletsIntegrationConfigView1.collectionModel.selectedRow}"
                                                  selectionListener="#{bindings.OutletsIntegrationConfigView1.collectionModel.makeCurrent}"
                                                  rowSelection="single"
                                                  fetchSize="#{bindings.OutletsIntegrationConfigView1.rangeSize}"
                                                  filterModel="#{bindings.OutletsIntegrationConfigView1Query.queryDescriptor}"
                                                  filterVisible="true"
                                                  queryListener="#{bindings.OutletsIntegrationConfigView1Query.processQuery}"
                                                  varStatus="vs" id="t7" partialTriggers="::b16">
                                            <af:column sortProperty="#{bindings.OutletsIntegrationConfigView1.hints.OutletName.name}"
                                                       filterable="true" sortable="true" headerText="Outlet Name"
                                                       id="c16">
                                                <af:outputText value="#{row.OutletName}"
                                                               shortDesc="#{bindings.OutletsIntegrationConfigView1.hints.OutletName.tooltip}"
                                                               id="ot12"/>
                                            </af:column>
                                            <af:column sortProperty="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.name}"
                                                       filterable="true" sortable="true" headerText="Integration Mode"
                                                       id="c17">
                                                <!-- <af:inputText value="#{row.bindings.IntegMode.inputValue}"
                                                              label="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.label}"
                                                              required="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.mandatory}"
                                                              columns="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.displayWidth}"
                                                              maximumLength="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.precision}"
                                                              shortDesc="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.tooltip}"
                                                              id="it10">
                                                </af:inputText> -->
                                                <af:selectOneChoice value="#{row.bindings.IntegMode.inputValue}"
                                                              label="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.label}"
                                                              required="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.mandatory}"
                                                              shortDesc="#{bindings.OutletsIntegrationConfigView1.hints.IntegMode.tooltip}"
                                                              id="it10">
                                                    <af:selectItem label="None" value="NONE" id="si3"/>
                                                    <af:selectItem label="Automated" value="AUTOMATIC" id="si4"/>
                                                    <af:selectItem label="Manual" value="MANUAL" id="si5"/>
                                                    <f:validator binding="#{row.bindings.IntegMode.validator}"/>
                                                </af:selectOneChoice>
                                            </af:column>
                                        </af:table>
                                    </f:facet>
                                </af:decorativeBox>
                            </af:showDetailItem>
                        </af:panelTabbed>
                        <f:facet name="footer">
                            <af:toolbar id="t1">
                                <af:button actionListener="#{bindings.Commit.execute}" text="Commit"
                                           disabled="#{!bindings.Commit.enabled}" id="b1"/>
                                <af:button actionListener="#{bindings.Rollback.execute}" text="Rollback"
                                           disabled="#{!bindings.Rollback.enabled}" immediate="true" id="b2">
                                    <af:resetActionListener/>
                                </af:button>
                            </af:toolbar>
                        </f:facet>
                    </af:panelFormLayout>
                </f:facet>
                <f:facet name="start">
                    <af:panelAccordion discloseMany="false" id="pa2">
                        <af:showDetailItem text="General" id="general_pane">
                            <af:navigationPane hint="list" id="np1">
                                <af:commandNavigationItem id="email_notif" text="Email Notifcation Recipients"
                                                          action="adfMenu_GeneralSettings"/>
                            </af:navigationPane>
                        </af:showDetailItem>
                        <af:showDetailItem id="fusion_pane" text="Fusion">
                            <af:navigationPane hint="list" id="np2">
                                <af:commandNavigationItem id="cni10" text="Fusion Credentials"
                                                          action="adfMenu_FusionSettings"/>
                                <af:commandNavigationItem id="cni2" text="Fusion Sales MetaData"
                                                          action="adfMenu_FusionSettings"/>
                                <af:commandNavigationItem id="cni3" text="Fusion Receipt Method MetaData"
                                                          action="adfMenu_FusionSettings"/>
                            </af:navigationPane>
                        </af:showDetailItem>
                        <af:showDetailItem id="vendhq_pane" text="Vend HQ" disclosed="true">
                            <af:navigationPane hint="list" id="np3">
                                <af:commandNavigationItem id="cni9" text="VendHQ Credentials"/>
                                <af:commandNavigationItem id="cni4" text="VendHQ Registers"/>
                                <af:commandNavigationItem id="cni5" text="VendHQ Outlets"/>
                                <af:commandNavigationItem id="cni6" text="VendHQ Taxes"/>
                            </af:navigationPane>
                        </af:showDetailItem>
                        <af:showDetailItem id="opencart_pane" text="Opencart">
                            <af:navigationPane hint="list" id="np4">
                                <af:commandNavigationItem id="cni7" text="Opencart Credentials"
                                                          action="adfMenu_OpenCartSettings"/>
                                <af:commandNavigationItem id="cni8" text="Opencart Settings"
                                                          action="adfMenu_OpenCartSettings"/>
                                </af:navigationPane>
                        </af:showDetailItem>
                    </af:panelAccordion>
                </f:facet>
                <f:facet name="end"/>
                <f:attribute name="brandingMaxWidth" value="1920px"/>
                <f:attribute name="endWidth" value="150"/>
                <f:attribute name="startWidth" value="300"/>
            </af:pageTemplate>
        </af:form>
    </af:document>
</f:view>