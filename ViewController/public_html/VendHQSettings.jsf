<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE html>
<f:view xmlns:f="http://java.sun.com/jsf/core" xmlns:af="http://xmlns.oracle.com/adf/faces/rich">
    <af:document title="VendHQSettings.jsf" id="d1">
        <af:messages id="m1"/>
        <af:form id="f1">
            <af:pageTemplate viewId="/oracle/templates/responsiveTemplate.jspx" id="pt1">
                <f:facet name="header">
                    <af:outputText value="&nbsp;&nbsp;&nbsp;|&nbsp;&nbsp;&nbsp;Integration Middleware" id="ot9"/>
                </f:facet>
                <f:facet name="status"/>
                <f:facet name="appNav">
                    <af:link text="Home" id="l1" action="adfMenu_HomePage"/>
                </f:facet>
                <f:facet name="globalLinks"/>
                <f:facet name="footer"/>
                <f:facet name="center">
                    <af:panelFormLayout id="pfl1" maxColumns="3">
                        <af:panelTabbed position="above" id="pt2">
                            <af:showDetailItem text="Credential" id="credential">
                                <af:panelGroupLayout id="pgl3" layout="vertical" >
                                    <af:panelFormLayout id="pfl3" rows="3" maxColumns="2" labelAlignment="start">
                                        <af:inputText value="#{bindings.Region.inputValue}"
                                                      label="#{bindings.Region.hints.label}"
                                                      required="#{bindings.Region.hints.mandatory}"
                                                      columns="#{bindings.Region.hints.displayWidth}"
                                                      maximumLength="#{bindings.Region.hints.precision}"
                                                      shortDesc="#{bindings.Region.hints.tooltip}" id="it8">
                                            <f:validator binding="#{bindings.Region.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.DomainName.inputValue}"
                                                      label="#{bindings.DomainName.hints.label}"
                                                      required="#{bindings.DomainName.hints.mandatory}"
                                                      columns="#{bindings.DomainName.hints.displayWidth}"
                                                      maximumLength="#{bindings.DomainName.hints.precision}"
                                                      shortDesc="#{bindings.DomainName.hints.tooltip}" id="it5">
                                            <f:validator binding="#{bindings.DomainName.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.PersonalToken.inputValue}"
                                                      label="#{bindings.PersonalToken.hints.label}"
                                                      required="#{bindings.PersonalToken.hints.mandatory}"
                                                      columns="#{bindings.PersonalToken.hints.displayWidth}"
                                                      maximumLength="#{bindings.PersonalToken.hints.precision}"
                                                      shortDesc="#{bindings.PersonalToken.hints.tooltip}" id="it6"
                                                      secret="true">
                                            <f:validator binding="#{bindings.PersonalToken.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.FusionOrgCode.inputValue}"
                                                      label="#{bindings.FusionOrgCode.hints.label}"
                                                      required="#{bindings.FusionOrgCode.hints.mandatory}"
                                                      columns="#{bindings.FusionOrgCode.hints.displayWidth}"
                                                      maximumLength="#{bindings.FusionOrgCode.hints.precision}"
                                                      shortDesc="#{bindings.FusionOrgCode.hints.tooltip}" id="it9">
                                            <f:validator binding="#{bindings.FusionOrgCode.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.FusionTaxCode.inputValue}"
                                                      label="#{bindings.FusionTaxCode.hints.label}"
                                                      required="#{bindings.FusionTaxCode.hints.mandatory}"
                                                      columns="#{bindings.FusionTaxCode.hints.displayWidth}"
                                                      maximumLength="#{bindings.FusionTaxCode.hints.precision}"
                                                      shortDesc="#{bindings.FusionTaxCode.hints.tooltip}" id="it11">
                                            <f:validator binding="#{bindings.FusionTaxCode.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.TimezoneOffset.inputValue}"
                                                      label="#{bindings.TimezoneOffset.hints.label}"
                                                      required="#{bindings.TimezoneOffset.hints.mandatory}"
                                                      columns="#{bindings.TimezoneOffset.hints.displayWidth}"
                                                      maximumLength="#{bindings.TimezoneOffset.hints.precision}"
                                                      shortDesc="#{bindings.TimezoneOffset.hints.tooltip}" id="it7">
                                            <f:validator binding="#{bindings.TimezoneOffset.validator}"/>
                                            <af:convertNumber groupingUsed="false"
                                                              pattern="#{bindings.TimezoneOffset.format}"/>
                                        </af:inputText>
                                        <af:inputDate value="#{bindings.BusinessStartDate.inputValue}"
                                                      label="#{bindings.BusinessStartDate.hints.label}"
                                                      required="#{bindings.BusinessStartDate.hints.mandatory}"
                                                      columns="#{bindings.BusinessStartDate.hints.displayWidth}"
                                                      shortDesc="#{bindings.BusinessStartDate.hints.tooltip}" id="id4">
                                            <f:validator binding="#{bindings.BusinessStartDate.validator}"/>
                                            <af:convertDateTime pattern="#{bindings.BusinessStartDate.format}"/>
                                        </af:inputDate>
                                        <af:selectOneRadio label="#{bindings.Active.hints.label}"
                                                           requiredMessageDetail="Please select a status" id="sor1"
                                                           value="#{bindings.Active.inputValue}">
                                            <af:selectItem label="Active" value="Y" id="si1"/>
                                            <af:selectItem label="Inactive" value="N" id="si2"/>
                                            <f:validator binding="#{bindings.Active.validator}"/>
                                        </af:selectOneRadio>
                                        <f:facet name="footer">
                                            <af:toolbar id="pgl1">
                                                <af:toolbar id="pgl2">
                                                    <af:button actionListener="#{bindings.First.execute}" text="First"
                                                               disabled="#{!bindings.First.enabled}"
                                                               partialSubmit="true" id="b7"/>
                                                    <af:button actionListener="#{bindings.Previous.execute}"
                                                               text="Previous" disabled="#{!bindings.Previous.enabled}"
                                                               partialSubmit="true" id="b8"/>
                                                    <af:button actionListener="#{bindings.Next.execute}" text="Next"
                                                               disabled="#{!bindings.Next.enabled}" partialSubmit="true"
                                                               id="b9"/>
                                                    <af:button actionListener="#{bindings.Last.execute}" text="Last"
                                                               disabled="#{!bindings.Last.enabled}" partialSubmit="true"
                                                               id="b10"/>
                                                </af:toolbar>
                                                <af:button actionListener="#{bindings.Create.execute}" text="Create"
                                                           disabled="#{!bindings.Create.enabled}" id="b3"/>
                                                <af:button actionListener="#{bindings.Delete.execute}" text="Delete"
                                                           disabled="#{!bindings.Delete.enabled}" id="b12"/>
                                                <af:button text="Submit" id="b11"/>
                                            </af:toolbar>
                                        </f:facet>
                                    </af:panelFormLayout>
                                    <af:table value="#{bindings.VendhqCredentialsView2.collectionModel}" var="row"
                                              rows="#{bindings.VendhqCredentialsView2.rangeSize}"
                                              emptyText="#{bindings.VendhqCredentialsView2.viewable ? 'No data to display.' : 'Access Denied.'}"
                                              rowBandingInterval="0"
                                              selectedRowKeys="#{bindings.VendhqCredentialsView2.collectionModel.selectedRow}"
                                              selectionListener="#{bindings.VendhqCredentialsView2.collectionModel.makeCurrent}"
                                              rowSelection="single"
                                              fetchSize="#{bindings.VendhqCredentialsView2.rangeSize}"
                                              filterModel="#{bindings.VendhqCredentialsView2Query.queryDescriptor}"
                                              filterVisible="true"
                                              queryListener="#{bindings.VendhqCredentialsView2Query.processQuery}"
                                              varStatus="vs" id="t2" partialTriggers="::b7 ::b8 ::b9 ::b10 ::b3 ::b12">
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.Region.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.Region.label}"
                                                   id="c15">
                                            <af:outputText value="#{row.Region}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.Region.tooltip}"
                                                           id="ot11"/>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.DomainName.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.DomainName.label}"
                                                   id="c1">
                                            <af:outputText value="#{row.DomainName}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.DomainName.tooltip}"
                                                           id="ot1"/>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.PersonalToken.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.PersonalToken.label}"
                                                   id="c2">
                                            <af:outputText value="#{row.PersonalToken}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.PersonalToken.tooltip}"
                                                           id="ot2"/>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.FusionOrgCode.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.FusionOrgCode.label}"
                                                   id="c3">
                                            <af:outputText value="#{row.FusionOrgCode}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.FusionOrgCode.tooltip}"
                                                           id="ot3"/>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.FusionTaxCode.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.FusionTaxCode.label}"
                                                   id="c24">
                                            <af:outputText value="#{row.FusionTaxCode}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.FusionTaxCode.tooltip}"
                                                           id="ot13"/>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.TimezoneOffset.name}"
                                                   filterable="true" sortable="true"
                                                   headerText="#{bindings.VendhqCredentialsView2.hints.TimezoneOffset.label}"
                                                   id="c4">
                                            <af:outputText value="#{row.TimezoneOffset}"
                                                           shortDesc="#{bindings.VendhqCredentialsView2.hints.TimezoneOffset.tooltip}"
                                                           id="ot4">
                                                <af:convertNumber groupingUsed="false"
                                                                  pattern="#{bindings.VendhqCredentialsView2.hints.TimezoneOffset.format}"/>
                                            </af:outputText>
                                        </af:column>
                                        <af:column sortProperty="#{bindings.VendhqCredentialsView2.hints.BusinessStartDate.name}"
