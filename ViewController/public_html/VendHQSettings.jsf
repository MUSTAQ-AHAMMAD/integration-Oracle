                                <af:decorativeBox id="db2">
                                    <f:facet name="top">
                                        <af:toolbar id="t4">
                                            <af:selectOneChoice value="#{bindings.Selected_Region1.inputValue}"
                                                                label="Select Region"
                                                                required="#{bindings.Selected_Region1.hints.mandatory}"
                                                                shortDesc="#{bindings.Selected_Region1.hints.tooltip}"
